{
  "expo": {
    "name": "Pelada Pede Mais Uma",
    "slug": "pelada-pede-mais-uma",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "peladapedemaisuma",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon-football-beer.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.peladapedemaisuma.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "br.com.peladapedemaisuma.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-football-beer.png",
        "backgroundColor": "#0B3D2E"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita selecionar uma foto para o seu card de jogador.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "00374e15-c3c9-46fd-ab57-ebb23ee01635"
      }
    },
    "owner": "davidvegabr"
  }
}
