# Imagem pronta publicada em um registry, se não quiser construir localmente.
APP_IMAGE=pelada-pede-mais-uma:latest

# Porta pública e porta interna do container.
HOST_PORT=3000
PORT=3000

# Versões reproduzíveis usadas no build.
NODE_VERSION=22.19.0
WRANGLER_VERSION=4.92.0
WORKERD_VERSION=1.20260515.1

# Nome do volume persistente (banco D1 local e uploads R2 locais).
DATA_VOLUME_NAME=pelada-pede-mais-uma-data

# Observabilidade e recuperação de senha.
LOG_LEVEL=info
APP_BASE_URL=https://pelada.seudominio.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=peladapedemaisuma@gmail.com
SMTP_PASSWORD=senha-de-app-do-google
SMTP_FROM="Pelada Pede Mais Uma <peladapedemaisuma@gmail.com>"
